# 数据库配置（MySQL）
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/smartsweep?charset=utf8mb4

# 或者使用 SQLite（默认）
# DATABASE_URL=sqlite:///data/smartsweep_agent.db

# JWT 密钥（生产环境必须修改为随机字符串）
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production

# DashScope API Key
DASHSCOPE_API_KEY=your_dashscope_api_key

# Redis 配置（如果需要覆盖 config/redis.yml）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password
